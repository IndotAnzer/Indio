page {
  min-height: 100%;
  background: #080908;
  color: #f4ede7;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
}

view,
text,
button,
textarea,
image {
  box-sizing: border-box;
}

button {
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1.2;
}
